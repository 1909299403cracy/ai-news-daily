# ============================================================
# Push channels (fill at least one)
# ============================================================
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=-100123456789

# Email (SMTP)
EMAIL_TO=you@example.com
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ============================================================
# LLM via OpenRouter (https://openrouter.ai)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-xxx
# Recommended free tier: deepseek/deepseek-chat / google/gemini-2.0-flash-exp
OPENROUTER_MODEL=deepseek/deepseek-chat

# ============================================================
# Optional: extra API tokens
# (the pipeline still works without these)
# ============================================================
# REDDIT_CLIENT_ID=xxx
# REDDIT_CLIENT_SECRET=xxx
# YOUTUBE_API_KEY=xxx
# PRODUCT_HUNT_TOKEN=xxx

# ============================================================
# Runtime
# ============================================================
DATA_DIR=./data
# RSSHub instance (default public one works; you can host your own)
RSSHUB_BASE=https://rsshub.app
